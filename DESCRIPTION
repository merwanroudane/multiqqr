Package: mqqr
Type: Package
Title: Multivariate Quantile-on-Quantile Regression
Version: 1.0.0
Authors@R: c(
    person("Merwan", "Roudane",
           email = "merwanroudane920@gmail.com",
           role = c("aut", "cre", "cph")),
    person("Avik", "Sinha", role = "ctb",
           comment = "Original m-QQR methodology"),
